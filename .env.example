# Copy this file to .env for local development. Never commit .env.

# Required unless FILE_PIPE_AUTH_DISABLED=true.
FILE_PIPE_AUTH_USERNAME=admin
FILE_PIPE_AUTH_PASSWORD=change-this-password

# Strongly recommended for stable sessions across restarts.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
FILE_PIPE_SECRET_KEY=change-this-secret-key

# Local testing only. Do not enable on LAN or internet-facing deployments.
FILE_PIPE_AUTH_DISABLED=false

# Login rate limiting.
FILE_PIPE_LOGIN_RATE_LIMIT=5
FILE_PIPE_LOGIN_RATE_WINDOW_SECONDS=300

# Anonymous watch-room entry and viewer API rate limiting.
FILE_PIPE_PUBLIC_ACCESS_RATE_LIMIT=120
FILE_PIPE_PUBLIC_ACCESS_RATE_WINDOW_SECONDS=60

# Local testing only.
FILE_PIPE_LOGIN_RATE_LIMIT_DISABLED=false
FILE_PIPE_PUBLIC_ACCESS_RATE_LIMIT_DISABLED=false

# Set true when the Flask app is served only over HTTPS.
FILE_PIPE_SESSION_COOKIE_SECURE=false

# Optional WebRTC relay settings. A TURN relay is usually required for
# cellular, hotel Wi-Fi, strict corporate networks, or symmetric NAT.
FILE_PIPE_STUN_URLS=stun:stun.l.google.com:19302
# FILE_PIPE_TURN_URLS=turn:turn.example.com:3478,turns:turn.example.com:5349
# FILE_PIPE_TURN_USERNAME=file-pipe
# FILE_PIPE_TURN_CREDENTIAL=replace-with-turn-password
# FILE_PIPE_ICE_TRANSPORT_POLICY=all
# FILE_PIPE_ICE_SERVERS_JSON=[{"urls":"stun:stun.l.google.com:19302"},{"urls":["turn:turn.example.com:3478","turns:turn.example.com:5349"],"username":"file-pipe","credential":"replace-with-turn-password"}]

# Optional connector password consumed by local_connector.py.
FILE_PIPE_CONNECTOR_PASSWORD=change-this-connector-password
